{
  "name": "p2pchat",
  "version": "1.0.0",
  "description": "P2PChat - WebRTC P2P聊天应用，使用Cloudflare Pages Functions和KV存储，支持局域网和公网模式",
  "main": "index.html",
  "scripts": {
    "dev": "wrangler pages dev .",
    "deploy": "wrangler pages deploy .",
    "preview": "wrangler pages dev . --port 8080",
    "build": "echo 'Static files ready for deployment'",
    "lint": "echo 'Linting frontend files...'",
    "test": "echo 'No tests specified'"
  },
  "files": [
    "index.html",
    "styles.css", 
    "app.js",
    "functions/",
    "wrangler.toml"
  ],
  "keywords": [
    "p2pchat",
    "p2p",
    "webrtc",
    "websocket",
    "chat",
    "cloudflare",
    "real-time",
    "kv-storage",
    "lan",
    "internet",
    "peer-to-peer"
  ],
  "author": "chat78912",
  "license": "MIT",
  "devDependencies": {
    "wrangler": "^3.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chat78912/p2pchat.git"
  },
  "bugs": {
    "url": "https://github.com/chat78912/p2pchat/issues"
  },
  "homepage": "https://github.com/chat78912/p2pchat#readme",
  "directories": {
    "functions": "./functions"
  },
  "config": {
    "modes": {
      "lan": {
        "description": "局域网模式 - 优化本地网络连接",
        "maxUsers": 50,
        "heartbeat": "30s"
      },
      "internet": {
        "description": "公网模式 - 适用于跨网络连接", 
        "maxUsers": 20,
        "heartbeat": "20s"
      }
    }
  }
}
